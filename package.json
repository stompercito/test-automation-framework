{
  "name": "test-automation-framework",
  "version": "1.0.0",
  "description": "Playwright + Cucumber BDD test automation framework covering functional (UI/API) and non-functional (accessibility/performance) testing",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:all",
    "test:functional": "npx cucumber-js --config cucumber.config.js",
    "test:non-functional": "npx cucumber-js --config cucumber.config.js --profile nonfunctional",
    "test:api": "npx cucumber-js --config cucumber.config.js --profile api",
    "test:ui": "npx cucumber-js --config cucumber.config.js --profile ui",
    "test:ui:headed": "cross-env HEADLESS=false npm run test:ui",
    "test:accessibility": "npx cucumber-js --config cucumber.config.js --profile accessibility",
    "test:accessibility:headed": "cross-env HEADLESS=false npm run test:accessibility",
    "test:performance": "npx cucumber-js --config cucumber.config.js --profile performance",
    "test:smoke": "npx cucumber-js --config cucumber.config.js --tags \"@smoke\"",
    "report:cucumber:open": "start reports\\html\\cucumber-report.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stompercito/test-automation-framework.git"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "gherkin",
    "test-automation",
    "page-object-model",
    "functional-testing",
    "non-functional-testing",
    "accessibility",
    "performance"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/stompercito/test-automation-framework/issues"
  },
  "homepage": "https://github.com/stompercito/test-automation-framework#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/html-formatter": "^23.0.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.6.0",
    "allure-playwright": "^3.6.0",
    "axios": "^1.13.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
