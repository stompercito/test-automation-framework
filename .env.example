# --- Application Under Test ---------------------------------------------------
# Active option: local ShopTest app
BASE_URL=http://127.0.0.1:4173

# Uncomment this instead when the app is published to GitHub Pages
# BASE_URL=https://stompercito.github.io/web-application-for-automation/

# Mock API mode for ShopTest business logic tests
API_BASE_URL=mock:shoptest


# --- Authentication (example - replace with real values) ----------------------
TEST_USERNAME=test_user
TEST_PASSWORD=test_password

# --- Environment ---------------------------------------------------------------
# Valid values: local | staging | production
ENVIRONMENT=local

# --- Timeouts (ms) -------------------------------------------------------------
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# --- Playwright ---------------------------------------------------------------
HEADLESS=true
SLOW_MO=0
