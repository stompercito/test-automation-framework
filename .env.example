# --- Application Under Test ---------------------------------------------------
BASE_URL=https://wmxrwq14uc.execute-api.us-east-1.amazonaws.com/Prod/Account/Login
API_BASE_URL=https://wmxrwq14uc.execute-api.us-east-1.amazonaws.com/Prod

# --- Paylocity Authentication -------------------------------------------------
PAYLOCITY_USERNAME=replace_me
PAYLOCITY_PASSWORD=replace_me

# Optional API auth. If token is provided it has priority over basic auth.
API_AUTH_TOKEN=
API_AUTH_USERNAME=
API_AUTH_PASSWORD=

# Backward compatibility aliases (optional)
TEST_USERNAME=
TEST_PASSWORD=

# --- Environment ---------------------------------------------------------------
# Valid values: local | staging | production
ENVIRONMENT=staging

# --- Timeouts (ms) -------------------------------------------------------------
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
MAX_LOAD_TIME_MS=5000

# --- Playwright ---------------------------------------------------------------
HEADLESS=true
PW_VIDEO_MODE=retain-on-failure
SLOW_MO=0
