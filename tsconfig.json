{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@pages/*": ["shared/pages/*"],
      "@api-clients/*": ["shared/clients/*"]
    }
  },
  "include": ["src/**/*", "shared/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist", "reports"]
}
